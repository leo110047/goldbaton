{
  "name": "goldbaton",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first AI collaboration console",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "biome check . && tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "24.13.3",
    "typescript": "7.0.2"
  }
}
